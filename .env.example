# Copy to `.env` and fill in. Only the keys for the models you run are required.

# --- Gemini via Google Cloud Vertex AI ---
# https://docs.cloud.google.com/vertex-ai/generative-ai/docs/start/quickstart?usertype=adc
GEMINI_API_KEY=your_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# --- OpenAI (GPT-Audio / GPT-4o-audio) ---
OPENAI_API_KEY=your_api_key_here

# --- ElevenLabs (synthetic voice generation only) ---
# https://elevenlabs.io/app/developers/api-keys
ELEVENLABS_API_KEY=your_api_key_here

# --- Hugging Face (gated corpus download) ---
HF_TOKEN=your_token_here
